<script>
    struct $state {
        counter = $state(0),
    }
</script>

<div>
    <button onclick={|| counter += 1}>Increment</button>
    <p>
        Hello world!
        {#if counter > 5}
            <p>Bye!</p>
        {:else}
            <p>Hi!</p>
        {/if}
    </p>
    <p>Counter: {counter}</p>
    {#each 0..counter as i}
        <p>Count: {i}</p>
    {/each}
</div>