<script>
    import Button from "./Button.rsvelte";

    struct $state {
        counter = $state(0),
    }
</script>

<div>
    <button onclick={|| counter += 1}>Increment</button>
    <Button/>
    <p>
        Hello world!
        {#if counter > 5}
            <p>Bye!</p>
        {:else}
            <p>Hi!</p>
        {/if}
    </p>
    <p>Counter: {counter}</p>
    {#each 0..counter as i}
        <div class="count-row">
        {#each 0..*i as j}
            <p>{i} {j}</p>
        {/each}
        </div>
    {/each}
</div>

<style>
    .count-row {
        display: flex;
    }
</style>