<script>
    let counter = $state(0);

    fn increment() {
        counter += 1;
    }
</script>

<p>Counter: {counter}</p>
<button on:click={increment}>Increment</button>

<style>
    p {
        font-size: 1.5em;
    }
    button {
        padding: 0.5em 1em;
        font-size: 1em;
    }
</style>